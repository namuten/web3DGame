      │   └ players.ts            # 원격 플레이어 레퍼런스 맵
      ├ types/
      │   └ map.ts                # MapConfig 타입 정의
      └ ui/
          ├ characterSelect.ts    # 캐릭터 선택 화면 + 3D 프리뷰 스냅샷
