# 환경변수 템플릿 — 실제 값을 채워서 .env로 복사하세요
# 운영(Railway, Render 등)에서는 플랫폼 대시보드에서 직접 설정

# 서버 포트 (Railway/Render는 자동으로 주입, 로컬은 3000)
PORT=3000

# MongoDB 연결 URI
# 로컬:  mongodb://localhost:25321/web3dgame  (brew 기본 포트 25321)
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/web3dgame
MONGO_URL=mongodb://localhost:27017/web3dgame
