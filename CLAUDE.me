      ├ style.css                 # 전역 스타일
      ├ utils.ts                  # 공통 유틸리티
      ├ counter.ts
      ├ assets/                   # 정적 자산 (hero.png 등)
      ├ engine/
      │   ├ camera.ts             # 3인칭 카메라
      │   ├ renderer.ts           # WebGL 렌더러 초기화
      │   └ scene.ts              # Three.js 씬
      ├ game/
      │   ├ player.ts             # 로컬 플레이어 (이동·회전·HP·넉백)
      │   ├ characterModel.ts     # 캐릭터 3D 모델 생성 (꽃·바이저 등)
      │   ├ world.ts              # 맵 월드 (바닥·장애물·안개·시드 생성)
      │   ├ bullets.ts            # 탄환 시스템 (발사·충돌·이펙트)
      │   ├ monster.ts            # 보스 슬라임 (렌더링·물리·내장 오브젝트)
